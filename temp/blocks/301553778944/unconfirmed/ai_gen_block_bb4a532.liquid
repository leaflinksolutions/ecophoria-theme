{% doc %}
  @prompt
    A magazine-style editorial layout
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-magazine-layout-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-magazine-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-bottom: {{ block.settings.grid_gap }}px;
  }

  .ai-magazine-feature-{{ ai_gen_id }} {
    grid-column: span 8;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-magazine-feature-image-{{ ai_gen_id }} {
    width: 100%;
    height: 500px;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-magazine-feature-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-magazine-feature-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-magazine-feature-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-magazine-feature-content-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 40px;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.8), transparent);
    color: #ffffff;
  }

  .ai-magazine-feature-category-{{ ai_gen_id }} {
    display: inline-block;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 12px;
    color: {{ block.settings.accent_color }};
  }

  .ai-magazine-feature-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.feature_title_size }}px;
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 12px;
    color: #ffffff;
  }

  .ai-magazine-feature-excerpt-{{ ai_gen_id }} {
    font-size: 16px;
    line-height: 1.6;
    margin: 0 0 16px;
    color: rgba(255, 255, 255, 0.9);
  }

  .ai-magazine-feature-meta-{{ ai_gen_id }} {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.7);
  }

  .ai-magazine-sidebar-{{ ai_gen_id }} {
    grid-column: span 4;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-magazine-card-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    background-color: {{ block.settings.card_background }};
  }

  .ai-magazine-card-image-{{ ai_gen_id }} {
    width: 100%;
    height: 200px;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px {{ block.settings.border_radius }}px 0 0;
  }

  .ai-magazine-card-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-magazine-card-{{ ai_gen_id }}:hover .ai-magazine-card-image-{{ ai_gen_id }} img {
    transform: scale(1.05);
  }

  .ai-magazine-card-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-magazine-card-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-magazine-card-content-{{ ai_gen_id }} {
    padding: 20px;
  }

  .ai-magazine-card-category-{{ ai_gen_id }} {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 8px;
    color: {{ block.settings.accent_color }};
  }

  .ai-magazine-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    font-weight: 600;
    line-height: 1.3;
    margin: 0 0 8px;
    color: {{ block.settings.text_color }};
  }

  .ai-magazine-card-meta-{{ ai_gen_id }} {
    font-size: 13px;
    color: {{ block.settings.meta_color }};
  }

  .ai-magazine-secondary-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-magazine-secondary-card-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    background-color: {{ block.settings.card_background }};
  }

  .ai-magazine-secondary-image-{{ ai_gen_id }} {
    width: 100%;
    height: 180px;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px {{ block.settings.border_radius }}px 0 0;
  }

  .ai-magazine-secondary-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-magazine-secondary-card-{{ ai_gen_id }}:hover .ai-magazine-secondary-image-{{ ai_gen_id }} img {
    transform: scale(1.05);
  }

  .ai-magazine-secondary-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-magazine-secondary-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-magazine-secondary-content-{{ ai_gen_id }} {
    padding: 16px;
  }

  .ai-magazine-secondary-category-{{ ai_gen_id }} {
    display: inline-block;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 6px;
    color: {{ block.settings.accent_color }};
  }

  .ai-magazine-secondary-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.secondary_title_size }}px;
    font-weight: 600;
    line-height: 1.3;
    margin: 0 0 6px;
    color: {{ block.settings.text_color }};
  }

  .ai-magazine-secondary-meta-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.meta_color }};
  }

  .ai-magazine-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 989px) {
    .ai-magazine-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-magazine-feature-{{ ai_gen_id }},
    .ai-magazine-sidebar-{{ ai_gen_id }} {
      grid-column: span 1;
    }

    .ai-magazine-secondary-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-magazine-feature-image-{{ ai_gen_id }} {
      height: 350px;
    }

    .ai-magazine-feature-content-{{ ai_gen_id }} {
      padding: 24px;
    }

    .ai-magazine-feature-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.feature_title_size | times: 0.7 }}px;
    }
  }
{% endstyle %}

<magazine-layout-{{ ai_gen_id }} class="ai-magazine-layout-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-magazine-grid-{{ ai_gen_id }}">
    <article class="ai-magazine-feature-{{ ai_gen_id }}">
      <div class="ai-magazine-feature-image-{{ ai_gen_id }}">
        {% if block.settings.feature_image %}
          <img
            src="{{ block.settings.feature_image | image_url: width: 1200 }}"
            alt="{{ block.settings.feature_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.feature_image.width }}"
            height="{{ block.settings.feature_image.height }}"
          >
        {% else %}
          <div class="ai-magazine-feature-placeholder-{{ ai_gen_id }}">
            {{ 'hero-apparel-1' | placeholder_svg_tag }}
            <div class="ai-magazine-empty-state-{{ ai_gen_id }}">
              Add a featured image
            </div>
          </div>
        {% endif %}
      </div>
      <div class="ai-magazine-feature-content-{{ ai_gen_id }}">
        {% if block.settings.feature_category != blank %}
          <span class="ai-magazine-feature-category-{{ ai_gen_id }}">{{ block.settings.feature_category }}</span>
        {% endif %}
        {% if block.settings.feature_title != blank %}
          <h2 class="ai-magazine-feature-title-{{ ai_gen_id }}">{{ block.settings.feature_title }}</h2>
        {% endif %}
        {% if block.settings.feature_excerpt != blank %}
          <p class="ai-magazine-feature-excerpt-{{ ai_gen_id }}">{{ block.settings.feature_excerpt }}</p>
        {% endif %}
        {% if block.settings.feature_author != blank or block.settings.feature_date != blank %}
          <div class="ai-magazine-feature-meta-{{ ai_gen_id }}">
            {% if block.settings.feature_author != blank %}
              {{ block.settings.feature_author }}
            {% endif %}
            {% if block.settings.feature_author != blank and block.settings.feature_date != blank %}
              •
            {% endif %}
            {% if block.settings.feature_date != blank %}
              {{ block.settings.feature_date }}
            {% endif %}
          </div>
        {% endif %}
      </div>
    </article>

    <aside class="ai-magazine-sidebar-{{ ai_gen_id }}">
      {% for i in (1..2) %}
        {% liquid
          assign image_key = 'sidebar_image_' | append: i
          assign category_key = 'sidebar_category_' | append: i
          assign title_key = 'sidebar_title_' | append: i
          assign author_key = 'sidebar_author_' | append: i
          assign date_key = 'sidebar_date_' | append: i

          assign image = block.settings[image_key]
          assign category = block.settings[category_key]
          assign title = block.settings[title_key]
          assign author = block.settings[author_key]
          assign date = block.settings[date_key]
        %}

        <article class="ai-magazine-card-{{ ai_gen_id }}">
          <div class="ai-magazine-card-image-{{ ai_gen_id }}">
            {% if image %}
              <img
                src="{{ image | image_url: width: 600 }}"
                alt="{{ image.alt | escape }}"
                loading="lazy"
                width="{{ image.width }}"
                height="{{ image.height }}"
              >
            {% else %}
              <div class="ai-magazine-card-placeholder-{{ ai_gen_id }}">
                {{ 'product-apparel-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          <div class="ai-magazine-card-content-{{ ai_gen_id }}">
            {% if category != blank %}
              <span class="ai-magazine-card-category-{{ ai_gen_id }}">{{ category }}</span>
            {% endif %}
            {% if title != blank %}
              <h3 class="ai-magazine-card-title-{{ ai_gen_id }}">{{ title }}</h3>
            {% else %}
              <h3 class="ai-magazine-card-title-{{ ai_gen_id }}">Article title {{ i }}</h3>
            {% endif %}
            {% if author != blank or date != blank %}
              <div class="ai-magazine-card-meta-{{ ai_gen_id }}">
                {% if author != blank %}
                  {{ author }}
                {% endif %}
                {% if author != blank and date != blank %}
                  •
                {% endif %}
                {% if date != blank %}
                  {{ date }}
                {% endif %}
              </div>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </aside>
  </div>

  <div class="ai-magazine-secondary-grid-{{ ai_gen_id }}">
    {% for i in (1..3) %}
      {% liquid
        assign image_key = 'secondary_image_' | append: i
        assign category_key = 'secondary_category_' | append: i
        assign title_key = 'secondary_title_' | append: i
        assign author_key = 'secondary_author_' | append: i
        assign date_key = 'secondary_date_' | append: i

        assign image = block.settings[image_key]
        assign category = block.settings[category_key]
        assign title = block.settings[title_key]
        assign author = block.settings[author_key]
        assign date = block.settings[date_key]
      %}

      <article class="ai-magazine-secondary-card-{{ ai_gen_id }}">
        <div class="ai-magazine-secondary-image-{{ ai_gen_id }}">
          {% if image %}
            <img
              src="{{ image | image_url: width: 500 }}"
              alt="{{ image.alt | escape }}"
              loading="lazy"
              width="{{ image.width }}"
              height="{{ image.height }}"
            >
          {% else %}
            <div class="ai-magazine-secondary-placeholder-{{ ai_gen_id }}">
              {{ 'collection-apparel-1' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
        <div class="ai-magazine-secondary-content-{{ ai_gen_id }}">
          {% if category != blank %}
            <span class="ai-magazine-secondary-category-{{ ai_gen_id }}">{{ category }}</span>
          {% endif %}
          {% if title != blank %}
            <h3 class="ai-magazine-secondary-title-{{ ai_gen_id }}">{{ title }}</h3>
          {% else %}
            <h3 class="ai-magazine-secondary-title-{{ ai_gen_id }}">Article title {{ i }}</h3>
          {% endif %}
          {% if author != blank or date != blank %}
            <div class="ai-magazine-secondary-meta-{{ ai_gen_id }}">
              {% if author != blank %}
                {{ author }}
              {% endif %}
              {% if author != blank and date != blank %}
                •
              {% endif %}
              {% if date != blank %}
                {{ date }}
              {% endif %}
            </div>
          {% endif %}
        </div>
      </article>
    {% endfor %}
  </div>
</magazine-layout-{{ ai_gen_id }}>

<script>
  (function() {
    class MagazineLayout{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('magazine-layout-{{ ai_gen_id }}', MagazineLayout{{ ai_gen_id }});
  })();
</script>

