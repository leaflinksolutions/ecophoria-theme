{%- liquid
  assign primary_link = section.settings.primary_link
  if primary_link == blank
    assign primary_link = routes.all_products_collection_url
  endif
  assign secondary_link = section.settings.secondary_link
  if secondary_link == blank
    assign secondary_link = '/pages/about'
  endif
  assign slide_count = section.blocks.size
-%}

<div class="eco-root eco-hero-root" id="eco-hero-{{ section.id }}" style="--font-scale: {{ section.settings.font_scale | default: 100 | divided_by: 100.0 }}; --mobile-fit: {{ section.settings.mobile_image_fit | default: 'contain' }};">

  <p class="eco-sr-only">Ecophoria is a Canadian clean vegan skincare brand offering cruelty-free products with clinically proven actives including niacinamide, vitamin C, hyaluronic acid, and botanical extracts. Plant-powered, sustainably packaged luxury skincare. Free shipping available across Canada.</p>

  <section class="eco-hero" style="--eco-hero-height: {% case section.settings.hero_height %}{% when 'small' %}60vh{% when 'medium' %}80vh{% else %}100vh{% endcase %}" aria-labelledby="EcoHeroHeading-{{ section.id }}">

    <div
      class="eco-hero__slideshow"
      role="region"
      aria-roledescription="carousel"
      aria-label="{{ section.settings.carousel_label | default: 'Hero slideshow' | escape }}"
      data-eco-carousel
      data-interval="{{ section.settings.slide_interval | default: '6000' }}"
      tabindex="0"
    >
      {% if slide_count > 0 %}
        {% for block in section.blocks %}
          {%- assign idx = forloop.index0 -%}
          {%- assign img_loading = 'eager' -%}
          {%- if idx == 0 -%}
            {%- assign img_priority = 'high' -%}
          {%- else -%}
            {%- assign img_priority = 'low' -%}
          {%- endif -%}
          <div
            class="eco-hero__slide{% if idx == 0 %} is-active{% endif %}"
            role="group"
            aria-roledescription="slide"
            aria-label="Slide {{ forloop.index }} of {{ slide_count }}"
            aria-hidden="{% if idx == 0 %}false{% else %}true{% endif %}"
            data-slide-index="{{ idx }}"
            {{ block.shopify_attributes }}
          >
            {% if block.settings.image != blank %}
              {{
                block.settings.image
                | image_url: width: 2400
                | image_tag:
                  widths: '600,900,1200,1600,2000,2400',
                  sizes: '100vw',
                  loading: img_loading,
                  fetchpriority: img_priority,
                  alt: block.settings.image_alt | default: 'Ecophoria skincare'
              }}
            {% else %}
              <div class="eco-hero__placeholder" aria-hidden="true"></div>
            {% endif %}
          </div>
        {% endfor %}
      {% else %}
        <div class="eco-hero__slide is-active" role="group" aria-roledescription="slide" aria-label="Slide 1 of 1" aria-hidden="false">
          <div class="eco-hero__placeholder" aria-hidden="true"></div>
        </div>
      {% endif %}

      <div class="eco-hero__overlay" style="--overlay-opacity: {{ section.settings.overlay_opacity | default: 60 | divided_by: 100.0 }}" aria-hidden="true"></div>
    </div>

    <div class="eco-container eco-hero__inner">
      <div class="eco-hero__content eco-hero__content--center">

        {% if section.settings.eyebrow != blank %}
          <p class="eco-eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}

        <h1 id="EcoHeroHeading-{{ section.id }}" class="eco-hero__heading eco-hero__heading--{{ section.settings.heading_size | default: 'large' }}">
          {{ section.settings.heading }}
        </h1>

        {% if section.settings.subheading != blank %}
          <p class="eco-hero__sub">{{ section.settings.subheading }}</p>
        {% endif %}

        <div class="eco-hero__cta">
          <a class="eco-btn eco-btn--primary" href="{{ primary_link }}">
            {{ section.settings.primary_text | default: 'Shop Skincare' }}
          </a>
          <a class="eco-btn eco-btn--silver" href="{{ secondary_link }}">
            {{ section.settings.secondary_text | default: 'Our Story' }}
          </a>
        </div>

        {% if section.settings.badges != blank %}
          <ul class="eco-hero__trust" aria-label="Brand trust badges">
            {% assign badges = section.settings.badges | split: '|' %}
            {% for badge in badges %}
              <li>{{ badge | strip }}</li>
            {% endfor %}
          </ul>
        {% endif %}

      </div>
    </div>

    {% if slide_count > 1 %}
      <div class="eco-hero__controls">
        <button
          type="button"
          class="eco-hero__pause"
          data-eco-pause
          aria-pressed="false"
          aria-label="Pause hero slideshow"
        >
          <span class="eco-hero__pause-icon" aria-hidden="true"></span>
          <span class="eco-sr-only">Pause</span>
        </button>

        <div class="eco-hero__dots" role="tablist" aria-label="Hero slide selection">
          {% for i in (1..slide_count) %}
            <button
              type="button"
              class="eco-hero__dot{% if forloop.first %} is-active{% endif %}"
              data-eco-goto="{{ forloop.index0 }}"
              role="tab"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              aria-label="Go to slide {{ forloop.index }}"
            ></button>
          {% endfor %}
        </div>
      </div>
    {% endif %}

  </section>
</div>

{% stylesheet %}
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Outfit:wght@300;400;500;600&display=swap');

  .eco-hero-root {
    --eco-bg: #080808;
    --eco-text: #f0efe8;
    --eco-text-soft: rgba(240, 239, 232, 0.68);
    --eco-accent: #2e5a45;
    --eco-accent-light: #3a7a5c;
    --eco-accent-glow: rgba(46, 90, 69, 0.4);
    --eco-silver: #b8b8bd;
    --eco-silver-light: #d4d4d8;
    --eco-silver-dark: #8a8a90;
    --eco-border: rgba(180, 180, 185, 0.12);
    --eco-glass: rgba(255, 255, 255, 0.04);
    --eco-font-display: 'Cormorant Garamond', 'Garamond', Georgia, serif;
    --eco-font-body: 'Outfit', -apple-system, 'Helvetica Neue', Arial, sans-serif;
    background: var(--eco-bg);
    color: var(--eco-text);
    font-family: var(--eco-font-body);
    -webkit-font-smoothing: antialiased;
  }

  .eco-hero-root *,
  .eco-hero-root *::before,
  .eco-hero-root *::after {
    box-sizing: border-box;
  }

  .eco-sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .eco-container {
    max-width: 1360px;
    margin: 0 auto;
    padding: 0 clamp(16px, 4vw, 28px);
  }

  .eco-eyebrow {
    font-size: calc(0.85rem * var(--font-scale, 1));
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #7fb89a;
    margin: 0 0 12px;
    text-shadow: 0 0 20px rgba(127, 184, 154, 0.5), 0 1px 2px rgba(0,0,0,0.8);
  }

  .eco-hero-root .eco-eyebrow {
    color: #a8d5b8 !important;
    text-shadow: 0 0 24px rgba(168, 213, 184, 0.6), 0 2px 4px rgba(0,0,0,0.9);
    font-weight: 700;
    font-size: calc(0.88rem * var(--font-scale, 1));
    letter-spacing: 0.2em;
    margin-bottom: 16px;
  }

  .eco-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--eco-font-body);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 32px;
    padding: 14px 34px;
    cursor: pointer;
    border: 1px solid transparent;
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .eco-btn--primary {
    background: var(--eco-accent);
    color: var(--eco-text);
    box-shadow: 0 0 24px var(--eco-accent-glow);
  }

  .eco-btn--primary:hover,
  .eco-btn--primary:focus-visible {
    background: var(--eco-accent-light);
    transform: translateY(-2px);
    outline: none;
  }

  .eco-btn--silver {
    background: var(--eco-glass);
    color: var(--eco-silver-light);
    border-color: var(--eco-border);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .eco-btn--silver:hover,
  .eco-btn--silver:focus-visible {
    border-color: var(--eco-silver);
    color: #fff;
    transform: translateY(-2px);
    outline: none;
  }

  .eco-btn:focus-visible {
    outline: 2px solid var(--eco-silver-light);
    outline-offset: 3px;
  }

  /* ---- Hero layout ---- */

  .eco-hero {
    position: relative;
    min-height: var(--eco-hero-height, 100vh);
    display: flex;
    align-items: center;
    padding: clamp(80px, 12vh, 120px) 0 clamp(100px, 14vh, 140px);
    overflow: hidden;
    background: var(--eco-bg);
  }

  /* ---- Slideshow ---- */

  .eco-hero__slideshow {
    position: absolute;
    inset: 0;
    z-index: 0;
    outline: none;
  }

  .eco-hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 1.2s ease-in-out;
    pointer-events: none;
  }

  .eco-hero__slide.is-active {
    opacity: 1;
    pointer-events: auto;
  }

  .eco-hero__slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .eco-hero__placeholder {
    width: 100%;
    height: 100%;
    background:
      radial-gradient(ellipse 80% 50% at 20% 50%, rgba(46, 90, 69, 0.18) 0%, transparent 70%),
      radial-gradient(ellipse 60% 40% at 80% 30%, rgba(92, 224, 208, 0.06) 0%, transparent 60%),
      linear-gradient(135deg, #0c0a08 0%, #080808 60%, #0a0d0c 100%);
  }

  .eco-hero__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(8,8,8,0.55) 0%, rgba(8,8,8,0.4) 40%, rgba(8,8,8,0.75) 85%, var(--eco-bg) 100%),
      radial-gradient(ellipse 70% 60% at 25% 60%, rgba(46,90,69,0.18) 0%, transparent 70%);
    opacity: var(--overlay-opacity, 0.6);
    pointer-events: none;
  }

  /* ---- Content ---- */

  .eco-hero__inner {
    position: relative;
    z-index: 2;
    width: 100%;
  }

  .eco-hero__content {
    max-width: 680px;
  }

  .eco-hero__content--center {
    text-align: left;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .eco-hero__heading {
    font-family: var(--eco-font-display);
    font-weight: 300;
    font-size: calc(clamp(2.25rem, 5.5vw, 3.8rem) * var(--font-scale, 1));
    line-height: 1.06;
    letter-spacing: -0.01em;
    margin: 0 0 20px;
    color: var(--eco-text);
    text-shadow: 0 2px 20px rgba(0,0,0,0.6);
  }

  .eco-hero__heading--small { font-size: calc(clamp(1.75rem, 4vw, 2.8rem) * var(--font-scale, 1)); }
  .eco-hero__heading--medium { font-size: calc(clamp(2rem, 5vw, 3.4rem) * var(--font-scale, 1)); }
  .eco-hero__heading--large { font-size: calc(clamp(2.25rem, 5.5vw, 3.8rem) * var(--font-scale, 1)); }

  .eco-hero__sub {
    font-size: calc(clamp(1rem, 1.8vw, 1.15rem) * var(--font-scale, 1));
    font-weight: 300;
    color: var(--eco-text-soft);
    margin: 0 0 36px;
    max-width: 52ch;
    line-height: 1.8;
    text-shadow: 0 1px 10px rgba(0,0,0,0.5);
  }

  .eco-hero__cta {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-start;
    gap: 12px;
    margin-bottom: 40px;
  }

  .eco-hero__trust {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-start;
    gap: 8px;
    padding: 0;
    margin: 0;
  }

  .eco-hero__trust li {
    font-size: calc(0.78rem * var(--font-scale, 1));
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #d4d4d8;
    padding: 10px 18px;
    border: 1px solid rgba(127, 184, 154, 0.3);
    border-radius: 32px;
    background: rgba(46, 90, 69, 0.15);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    box-shadow: 0 0 16px rgba(46, 90, 69, 0.25), inset 0 1px 0 rgba(255,255,255,0.08);
    transition: box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .eco-hero__trust li:hover {
    box-shadow: 0 0 24px rgba(127, 184, 154, 0.5);
    border-color: #7fb89a;
  }

  /* ---- Controls ---- */

  .eco-hero__controls {
    position: absolute;
    bottom: clamp(20px, 3vh, 32px);
    left: 50%;
    transform: translateX(-50%);
    z-index: 4;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .eco-hero__pause {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 1px solid var(--eco-border);
    background: var(--eco-glass);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    flex-shrink: 0;
  }

  .eco-hero__pause-icon {
    display: block;
    width: 9px;
    height: 11px;
    border-left: 3px solid var(--eco-silver-light);
    border-right: 3px solid var(--eco-silver-light);
    transition: border 0.2s ease;
  }

  .eco-hero__pause[aria-pressed="true"] .eco-hero__pause-icon {
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 5px 0 5px 9px;
    border-color: transparent transparent transparent var(--eco-silver-light);
    margin-left: 2px;
  }

  .eco-hero__dots {
    display: flex;
    gap: 9px;
  }

  .eco-hero__dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    border: 1.5px solid var(--eco-silver-dark);
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: all 0.3s ease;
  }

  .eco-hero__dot.is-active {
    background: var(--eco-silver-light);
    border-color: var(--eco-silver-light);
  }

  /* ---- Mobile: full image stacked layout ---- */

  @media (max-width: 749px) {
    .eco-hero {
      min-height: auto !important;
      display: flex !important;
      flex-direction: column !important;
      padding: 0 !important;
    }

    .eco-hero__slideshow {
      position: relative !important;
      height: auto !important;
      aspect-ratio: 3 / 4;
      width: 100% !important;
      flex-shrink: 0;
    }

    .eco-hero__slide {
      position: absolute !important;
      inset: 0 !important;
    }

    .eco-hero__slide img {
      object-fit: var(--mobile-fit, contain) !important;
      object-position: center center !important;
      background: var(--eco-bg, #080808);
    }

    .eco-hero__overlay {
      display: none !important;
    }

    .eco-hero__inner {
      position: relative !important;
      padding: 32px 20px 48px !important;
      background: var(--eco-bg, #080808);
    }

    .eco-hero__content {
      max-width: 100% !important;
    }

    .eco-hero__controls {
      position: absolute !important;
      bottom: 12px !important;
      left: 50% !important;
      transform: translateX(-50%) !important;
      z-index: 5 !important;
    }

    .eco-hero__cta {
      flex-direction: column;
      width: 100%;
    }

    .eco-hero__cta .eco-btn {
      width: 100%;
    }
  }

  /* ---- Responsive (601–749px handled above) ---- */

  @media (max-width: 600px) {
    .eco-hero__cta {
      flex-direction: column;
      width: 100%;
    }

    .eco-hero__cta .eco-btn {
      width: 100%;
    }
  }

  /* ---- Design mode ---- */

  body.shopify-design-mode .eco-hero__slide {
    transition: none !important;
  }

  /* ---- Reduced motion ---- */

  @media (prefers-reduced-motion: reduce) {
    .eco-hero__slide,
    .eco-btn,
    .eco-hero__trust li,
    .eco-hero__dot,
    .eco-hero__pause-icon {
      transition: none !important;
    }
  }
{% endstylesheet %}

<script>
  (function () {
    var root = document.getElementById('eco-hero-{{ section.id }}');
    if (!root) return;

    var carousel = root.querySelector('[data-eco-carousel]');
    if (!carousel) return;

    var slides = carousel.querySelectorAll('.eco-hero__slide');
    if (slides.length < 2) return;

    var dots    = root.querySelectorAll('[data-eco-goto]');
    var pauseBtn = root.querySelector('[data-eco-pause]');
    var interval = parseInt(carousel.getAttribute('data-interval'), 10) || 6000;
    var current  = 0;
    var timer    = null;
    var paused   = false;
    var reduced  = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var designMode = document.body.classList.contains('shopify-design-mode');

    function goTo(index) {
      if (index === current) return;
      slides[current].classList.remove('is-active');
      slides[current].setAttribute('aria-hidden', 'true');
      if (dots[current]) {
        dots[current].classList.remove('is-active');
        dots[current].setAttribute('aria-selected', 'false');
      }
      current = (index + slides.length) % slides.length;
      slides[current].classList.add('is-active');
      slides[current].setAttribute('aria-hidden', 'false');
      if (dots[current]) {
        dots[current].classList.add('is-active');
        dots[current].setAttribute('aria-selected', 'true');
      }
    }

    function next() { goTo(current + 1); }

    function start() {
      if (paused || reduced || designMode) return;
      stop();
      timer = window.setInterval(next, interval);
    }

    function stop() {
      if (timer) { window.clearInterval(timer); timer = null; }
    }

    for (var i = 0; i < dots.length; i++) {
      dots[i].addEventListener('click', function (e) {
        var idx = parseInt(e.currentTarget.getAttribute('data-eco-goto'), 10);
        goTo(idx);
        if (!paused) start();
      });
    }

    if (pauseBtn) {
      pauseBtn.addEventListener('click', function () {
        paused = !paused;
        pauseBtn.setAttribute('aria-pressed', paused ? 'true' : 'false');
        pauseBtn.setAttribute('aria-label', paused ? 'Play hero slideshow' : 'Pause hero slideshow');
        if (paused) stop(); else start();
      });
    }

    carousel.addEventListener('keydown', function (e) {
      if (e.key === 'ArrowLeft')  { goTo(current - 1); if (!paused) start(); }
      if (e.key === 'ArrowRight') { goTo(current + 1); if (!paused) start(); }
    });

    carousel.addEventListener('mouseenter', stop);
    carousel.addEventListener('mouseleave', function () { if (!paused) start(); });

    if (designMode) {
      paused = true;
      document.addEventListener('shopify:block:select', function (evt) {
        var blockEl = evt.target;
        if (!root.contains(blockEl)) return;
        var idx = parseInt(blockEl.getAttribute('data-slide-index'), 10);
        if (isNaN(idx)) return;
        stop();
        for (var s = 0; s < slides.length; s++) {
          slides[s].classList.remove('is-active');
          slides[s].setAttribute('aria-hidden', 'true');
          if (dots[s]) { dots[s].classList.remove('is-active'); dots[s].setAttribute('aria-selected', 'false'); }
        }
        current = idx;
        slides[current].classList.add('is-active');
        slides[current].setAttribute('aria-hidden', 'false');
        if (dots[current]) { dots[current].classList.add('is-active'); dots[current].setAttribute('aria-selected', 'true'); }
      });
    } else {
      start();
    }
  })();
</script>

{% schema %}
{
  "name": "Hero - Ecophoria",
  "tag": "section",
  "class": "shopify-section-eco-hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Clean vegan skincare where nature meets luxury"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Clean Vegan Skincare That Delivers Real Results"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Plant-powered formulas with clinically proven actives designed for radiant healthy skin."
    },
    {
      "type": "text",
      "id": "primary_text",
      "label": "Primary button text",
      "default": "Shop Skincare"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_text",
      "label": "Secondary button text",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "text",
      "id": "badges",
      "label": "Trust badges (pipe-separated)",
      "default": "100% Vegan|Cruelty-Free|Certified Leaping Bunny|Clean Ingredients|No Parabens|No Sulfates"
    },
    {
      "type": "select",
      "id": "slide_interval",
      "label": "Slide interval",
      "options": [
        { "value": "3000", "label": "3 seconds" },
        { "value": "4000", "label": "4 seconds" },
        { "value": "5000", "label": "5 seconds" },
        { "value": "6000", "label": "6 seconds" },
        { "value": "8000", "label": "8 seconds" },
        { "value": "10000", "label": "10 seconds" }
      ],
      "default": "6000"
    },
    {
      "type": "text",
      "id": "carousel_label",
      "label": "Carousel accessibility label",
      "default": "Hero slideshow"
    },
    {
      "type": "header",
      "content": "Display"
    },
    {
      "type": "select",
      "id": "hero_height",
      "label": "Hero height",
      "options": [
        { "value": "small", "label": "Small (60vh)" },
        { "value": "medium", "label": "Medium (80vh)" },
        { "value": "large", "label": "Large (100vh)" }
      ],
      "default": "large"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 60,
      "unit": "%"
