<div class="eco-root eco-ben-root" id="eco-benefits-{{ section.id }}">
  <section class="eco-benefits" aria-labelledby="EcoBenHeading-{{ section.id }}">
    <div class="eco-container">

      <header class="eco-section-header eco-reveal">
        <p class="eco-eyebrow">{{ section.settings.eyebrow }}</p>
        <h2 id="EcoBenHeading-{{ section.id }}" class="eco-heading">
          {{ section.settings.heading }}
        </h2>
      </header>

      <ul class="eco-ben__grid" role="list">
        {% for block in section.blocks %}
          {% if block.type == 'benefit' %}
            <li class="eco-ben__card eco-reveal" {{ block.shopify_attributes }}>
              {% if block.settings.icon_image != blank %}
                <span class="eco-ben__icon" aria-hidden="true">
                  {{
                    block.settings.icon_image
                    | image_url: width: 80
                    | image_tag:
                      widths: '40,60,80',
                      loading: 'lazy',
                      class: 'eco-ben__icon-img',
                      alt: ''
                  }}
                </span>
              {% elsif block.settings.icon != blank %}
                <span class="eco-ben__icon" aria-hidden="true">{{ block.settings.icon }}</span>
              {% endif %}
              <h3 class="eco-ben__title">{{ block.settings.title }}</h3>
              <p class="eco-ben__text">{{ block.settings.text }}</p>
            </li>
          {% endif %}
        {% endfor %}

        {% if section.blocks.size == 0 %}
          <li class="eco-ben__empty" role="status">
            <p>Add benefit blocks in the theme editor to populate this section.</p>
          </li>
        {% endif %}
      </ul>

      {% if section.settings.cta_link != blank %}
        <div class="eco-ben__footer eco-reveal">
          <a class="eco-btn eco-btn--silver" href="{{ section.settings.cta_link }}">
            {{ section.settings.cta_text | default: 'Explore Benefits' }}
          </a>
        </div>
      {% endif %}

    </div>
  </section>
  <hr class="eco-divider" aria-hidden="true">
</div>

{% stylesheet %}
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Outfit:wght@300;400;500;600&display=swap');

  .eco-ben-root {
    --eco-bg: #080808;
    --eco-text: #f0efe8;
    --eco-text-soft: rgba(240, 239, 232, 0.6);
    --eco-accent-light: #3a7a5c;
    --eco-accent-glow: rgba(46, 90, 69, 0.4);
    --eco-silver: #b8b8bd;
    --eco-silver-light: #d4d4d8;
    --eco-border: rgba(180, 180, 185, 0.12);
    --eco-glass: rgba(255, 255, 255, 0.04);
    --eco-font-display: 'Cormorant Garamond', 'Garamond', Georgia, serif;
    --eco-font-body: 'Outfit', -apple-system, 'Helvetica Neue', Arial, sans-serif;
    background: var(--eco-bg);
    color: var(--eco-text);
    font-family: var(--eco-font-body);
    -webkit-font-smoothing: antialiased;
  }
  .eco-ben-root *,
  .eco-ben-root *::before,
  .eco-ben-root *::after {
    box-sizing: border-box;
  }
  .eco-benefits {
    padding: clamp(60px, 10vw, 100px) 0;
    background: var(--eco-bg);
  }
  .eco-container {
    max-width: 1360px;
    margin: 0 auto;
    padding: 0 clamp(16px, 4vw, 28px);
  }
  .eco-section-header {
    text-align: center;
    margin-bottom: clamp(32px, 5vw, 56px);
  }
  .eco-eyebrow {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--eco-accent-light);
    margin: 0 0 8px;
  }
  .eco-heading {
    font-family: var(--eco-font-display);
    font-weight: 400;
    font-size: clamp(1.75rem, 3.5vw, 2.6rem);
    line-height: 1.1;
    margin: 0;
    color: var(--eco-text);
    max-width: 32ch;
    margin-inline: auto;
  }
  .eco-ben__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    align-items: stretch;
  }
  @media (min-width: 600px) {
    .eco-ben__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
  }
  @media (min-width: 990px) {
    .eco-ben__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .eco-ben__card {
    text-align: center;
    background: var(--eco-glass);
    border: 1px solid var(--eco-border);
    border-radius: 16px;
    padding: clamp(24px, 4vw, 36px) 20px;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    position: relative;
    overflow: hidden;
  }
  .eco-ben__card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 50px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--eco-silver), transparent);
    opacity: 0.5;
    transition: all 0.4s ease;
  }
  .eco-ben__card:hover {
    transform: translateY(-4px);
    border-color: rgba(180, 180, 185, 0.22);
    box-shadow: 0 0 30px rgba(180, 180, 185, 0.05), 0 0 20px var(--eco-accent-glow);
  }
  .eco-ben__card:hover::before {
    opacity: 1;
    width: 60%;
  }
  .eco-ben__icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 14px;
  }

  .eco-ben__icon-img {
    width: 2rem;
    height: 2rem;
    object-fit: contain;
    display: block;
    margin: 0 auto;
  }
  .eco-ben__title {
    font-family: var(--eco-font-display);
    font-size: 1.3rem;
    font-weight: 500;
    margin: 0 0 8px;
    color: var(--eco-silver-light);
  }
  .eco-ben__text {
    font-size: 0.9rem;
    color: var(--eco-text-soft);
    margin: 0;
    line-height: 1.6;
  }
  .eco-ben__empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 40px 24px;
    background: var(--eco-glass);
    border: 1px solid var(--eco-border);
    border-radius: 16px;
    color: var(--eco-text-soft);
  }
  .eco-ben__footer {
    text-align: center;
    margin-top: clamp(32px, 5vw, 48px);
  }
  .eco-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--eco-font-body);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 32px;
    padding: 14px 34px;
    cursor: pointer;
    border: 1px solid transparent;
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .eco-btn--silver {
    background: var(--eco-glass);
    color: var(--eco-silver-light);
    border-color: var(--eco-border);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .eco-btn--silver:hover,
  .eco-btn--silver:focus-visible {
    border-color: var(--eco-silver);
    color: #fff;
    transform: translateY(-2px);
    outline: none;
  }
  .eco-divider {
    height: 1px;
    border: none;
    background: linear-gradient(90deg, transparent 5%, var(--eco-border) 30%, rgba(212, 212, 216, 0.15) 50%, var(--eco-border) 70%, transparent 95%);
    margin: 0;
  }
  .eco-reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .eco-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  body.shopify-design-mode .eco-reveal {
    opacity: 1 !important;
    transform: none !important;
  }
  @media (prefers-reduced-motion: reduce) {
    .eco-reveal,
    .eco-ben__card {
      transition: none !important;
      transform: none !important;
      opacity: 1 !important;
    }
  }
{% endstylesheet %}

<script>
  (function () {
    var root = document.getElementById('eco-benefits-{{ section.id }}');
    if (!root) return;
    var reveals = root.querySelectorAll('.eco-reveal');
    if (!reveals.length) return;
    if (document.body.classList.contains('shopify-design-mode') ||
        window.matchMedia('(prefers-reduced-motion: reduce)').matches ||
        !('IntersectionObserver' in window)) {
      for (var i = 0; i < reveals.length; i++) reveals[i].classList.add('is-visible');
      return;
    }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
    for (var j = 0; j < reveals.length; j++) io.observe(reveals[j]);
  })();
</script>

{% schema %}
{
  "name": "Benefits - Ecophoria",
  "tag": "section",
  "class": "shopify-section-eco-benefits",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "What your skin sees"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Targeted benefits for modern clean skincare routines"
    },
    {
      "type": "header",
      "content": "CTA Button"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "Explore Benefits"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "limit": 8,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon image (overrides emoji)"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji or symbol)",
          "default": "💧"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Hydration"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Moisture-locking formulas help skin feel soft, comfortable, and replenished."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Benefits - Ecophoria",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "icon": "💧",
