{%- liquid
  assign featured = section.settings.collection
  assign products_to_show = section.settings.products_to_show
  assign brand_name = section.settings.brand_name | default: 'Ecophoria'
-%}

<div class="eco-root eco-products-root" id="eco-products-{{ section.id }}">
  <section class="eco-products" aria-labelledby="EcoProductsHeading-{{ section.id }}">
    <div class="eco-container">

      <header class="eco-section-header eco-reveal">
        <p class="eco-eyebrow">{{ section.settings.eyebrow }}</p>
        <h2 id="EcoProductsHeading-{{ section.id }}" class="eco-heading">
          {{ section.settings.heading }}
        </h2>
      </header>

      {% if featured != blank and featured.products_count > 0 %}
        <ul class="eco-products__grid" role="list">
          {% for product in featured.products limit: products_to_show %}
            {%- assign variant = product.selected_or_first_available_variant -%}
            {%- assign image_alt = product.featured_image.alt | default: product.title -%}
            {%- assign second_image = product.images[1] -%}

            <li class="eco-pcard eco-reveal{% if second_image != blank %} eco-pcard--has-alt{% endif %}" itemscope itemtype="https://schema.org/Product">

              <a href="{{ product.url }}" class="eco-pcard__media" aria-label="View {{ product.title | escape }}">
                {% if product.featured_image != blank %}
                  {{
                    product.featured_image
                    | image_url: width: 800
                    | image_tag:
                      widths: '240,360,480,640,800',
                      sizes: '(min-width: 990px) 22vw, (min-width: 750px) 45vw, 100vw',
                      loading: 'lazy',
                      class: 'eco-pcard__img eco-pcard__img--primary',
                      alt: image_alt
                  }}
                  {%- if second_image != blank -%}
                    {{
                      second_image
                      | image_url: width: 800
                      | image_tag:
                        widths: '240,360,480,640,800',
                        sizes: '(min-width: 990px) 22vw, (min-width: 750px) 45vw, 100vw',
                        loading: 'lazy',
                        class: 'eco-pcard__img eco-pcard__img--alt',
                        alt: second_image.alt | default: image_alt
                    }}
                  {%- endif -%}
                {% else %}
                  <div class="eco-pcard__ph" aria-hidden="true"></div>
                {% endif %}

                {% if variant.compare_at_price > variant.price %}
                  <span class="eco-pcard__badge" aria-label="On sale">Sale</span>
                {% endif %}

                <span class="eco-pcard__aura" aria-hidden="true"></span>
              </a>

              <div class="eco-pcard__body">
                <p class="eco-pcard__vendor" itemprop="brand" itemscope itemtype="https://schema.org/Brand">
                  <span itemprop="name">{{ brand_name }}</span>
                </p>

                <h3 class="eco-pcard__title">
                  <a href="{{ product.url }}" itemprop="name">{{ product.title }}</a>
                </h3>

                {% if product.description != blank %}
                  <meta itemprop="description" content="{{ product.description | strip_html | truncate: 200 | escape }}">
                {% endif %}

                {% if product.featured_image != blank %}
                  <meta itemprop="image" content="https:{{ product.featured_image | image_url: width: 800 }}">
                {% endif %}

                <link itemprop="url" href="{{ shop.url }}{{ product.url }}">

                <div class="eco-pcard__price" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
                  <meta itemprop="priceCurrency" content="{{ cart.currency.iso_code }}">
                  <meta itemprop="price" content="{{ variant.price | money_without_currency | strip_html }}">
                  <span itemprop="seller" itemscope itemtype="https://schema.org/Organization">
                    <meta itemprop="name" content="{{ brand_name | escape }}">
                  </span>

                  {% if product.available %}
                    <link itemprop="availability" href="https://schema.org/InStock">
                  {% else %}
                    <link itemprop="availability" href="https://schema.org/OutOfStock">
                  {% endif %}

                  {% if variant.compare_at_price > variant.price %}
                    <s class="eco-pcard__compare" aria-label="Original price">{{ variant.compare_at_price | money }}</s>
                    <span class="eco-pcard__sale" aria-label="Sale price">{{ variant.price | money }}</span>
                  {% else %}
                    <span class="eco-pcard__regular">{{ variant.price | money }}</span>
                  {% endif %}
                </div>

                {% if product.available %}
                  <form method="post" action="/cart/add" class="eco-pcard__form">
                    <input type="hidden" name="id" value="{{ variant.id }}">
                    <input type="hidden" name="quantity" value="1">
                    <button type="submit" class="eco-btn eco-btn--glass eco-pcard__atc">
                      Add to Cart
                    </button>
                  </form>
                {% else %}
                  <p class="eco-pcard__sold">Sold Out</p>
                {% endif %}
              </div>
            </li>
          {% endfor %}
        </ul>

      {% else %}
        <div class="eco-products__empty eco-reveal" role="status">
          <p>{{ section.settings.empty_text | default: 'Select a collection in the theme editor to display products here.' }}</p>

          {% assign ph_count = products_to_show | default: 4 %}
          <ul class="eco-products__grid" role="list" aria-label="Placeholder products">
            {% for i in (1..ph_count) %}
              <li class="eco-pcard eco-pcard--ph" aria-hidden="true">
                <div class="eco-pcard__media">
                  <div class="eco-pcard__ph"></div>
                </div>
                <div class="eco-pcard__body">
                  <p class="eco-pcard__vendor">{{ brand_name }}</p>
                  <h3 class="eco-pcard__title">Product Name</h3>
                  <div class="eco-pcard__price">
                    <span class="eco-pcard__regular">$00.00</span>
                  </div>
                  <button type="button" class="eco-btn eco-btn--glass eco-pcard__atc" disabled>
                    Add to Cart
                  </button>
                </div>
              </li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}

      {% if section.settings.view_all_link != blank %}
        <div class="eco-products__footer eco-reveal">
          <a class="eco-btn eco-btn--silver" href="{{ section.settings.view_all_link }}">
            {{ section.settings.view_all_text | default: 'View All Products' }}
          </a>
        </div>
      {% endif %}

    </div>
  </section>
  <hr class="eco-divider" aria-hidden="true">
</div>

{% stylesheet %}
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Outfit:wght@300;400;500;600&display=swap');

  .eco-products-root {
    --eco-bg: #080808;
    --eco-text: #f0efe8;
    --eco-text-soft: rgba(240, 239, 232, 0.6);
    --eco-text-mute: rgba(240, 239, 232, 0.3);
    --eco-accent: #2e5a45;
    --eco-accent-light: #3a7a5c;
    --eco-accent-glow: rgba(46, 90, 69, 0.4);
    --eco-silver: #b8b8bd;
    --eco-silver-light: #d4d4d8;
    --eco-silver-dark: #8a8a90;
    --eco-border: rgba(180, 180, 185, 0.12);
    --eco-glass: rgba(255, 255, 255, 0.04);
    --eco-glass-hover: rgba(255, 255, 255, 0.06);
    --eco-sale: #cf6b5e;
    --eco-font-display: 'Cormorant Garamond', 'Garamond', Georgia, serif;
    --eco-font-body: 'Outfit', -apple-system, 'Helvetica Neue', Arial, sans-serif;
    background: var(--eco-bg);
    color: var(--eco-text);
    font-family: var(--eco-font-body);
    -webkit-font-smoothing: antialiased;
  }

  .eco-products-root *,
  .eco-products-root *::before,
  .eco-products-root *::after {
    box-sizing: border-box;
  }

  .eco-products {
    padding: clamp(60px, 10vw, 100px) 0;
    background: var(--eco-bg);
  }

  .eco-container {
    max-width: 1360px;
    margin: 0 auto;
    padding: 0 clamp(16px, 4vw, 28px);
  }

  .eco-section-header {
    text-align: center;
    margin-bottom: clamp(32px, 5vw, 56px);
  }

  .eco-eyebrow {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--eco-accent-light);
    margin: 0 0 8px;
  }

  .eco-heading {
    font-family: var(--eco-font-display);
    font-weight: 400;
    font-size: clamp(1.75rem, 3.5vw, 2.6rem);
    line-height: 1.1;
    margin: 0;
    color: var(--eco-text);
    max-width: 24ch;
    margin-inline: auto;
  }

  .eco-products__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    align-items: stretch;
  }

  @media (min-width: 750px) {
    .eco-products__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
    }
  }

  .eco-pcard {
    background: var(--eco-glass);
    border: 1px solid var(--eco-border);
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .eco-pcard:hover {
    transform: translateY(-6px);
    border-color: rgba(46, 90, 69, 0.4);
    background: var(--eco-glass-hover);
    box-shadow: 0 8px 50px rgba(0, 0, 0, 0.5), 0 0 30px var(--eco-accent-glow);
  }

  .eco-pcard__media {
    display: block;
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #0d0d0d;
  }

  .eco-pcard__media img,
  .eco-pcard__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.5s ease;
  }

  .eco-pcard__img--alt {
    position: absolute;
    inset: 0;
    opacity: 0;
  }

  .eco-pcard--has-alt:hover .eco-pcard__img--primary {
    opacity: 0;
  }

  .eco-pcard--has-alt:hover .eco-pcard__img--alt {
    opacity: 1;
  }

  .eco-pcard:not(.eco-pcard--has-alt):hover .eco-pcard__media img {
    transform: scale(1.06);
  }

  .eco-products__footer {
    text-align: center;
    margin-top: clamp(32px, 5vw, 48px);
  }

  .eco-pcard__ph {
    width: 100%;
    height: 100%;
    background: linear-gradient(145deg, #0e0e0e, #161618);
  }

  .eco-pcard__aura {
    position: absolute;
    inset: 20%;
    border-radius: 50%;
    background: radial-gradient(circle, var(--eco-accent-glow) 0%, transparent 70%);
    opacity: 0;
    filter: blur(20px);
    transition: opacity 0.5s ease;
    pointer-events: none;
  }

  .eco-pcard:hover .eco-pcard__aura {
    opacity: 1;
  }

  .eco-pcard__badge {
    position: absolute;
    top: 10px;
    left: 10px;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 20px;
    background: var(--eco-sale);
    color: #fff;
    z-index: 2;
  }

  .eco-pcard__body {
    padding: 16px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .eco-pcard__vendor {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--eco-silver-dark);
    margin: 0 0 4px;
  }

  .eco-pcard__title {
    font-family: var(--eco-font-display);
    font-size: 1.05rem;
    font-weight: 500;
    line-height: 1.3;
    margin: 0 0 8px;
  }

  .eco-pcard__title a {
    text-decoration: none;
    color: var(--eco-text);
    transition: color 0.3s ease;
  }

  .eco-pcard__title a:hover,
  .eco-pcard__title a:focus-visible {
    color: var(--eco-accent-light);
    outline: none;
  }

  .eco-pcard__price {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--eco-silver-light);
    margin-bottom: auto;
    padding-bottom: 14px;
  }

  .eco-pcard__compare {
    color: var(--eco-text-mute);
    margin-right: 6px;
    text-decoration: line-through;
  }

  .eco-pcard__sale {
    color: var(--eco-sale);
    font-weight: 600;
  }

  .eco-pcard__form {
    margin-top: auto;
  }

  .eco-pcard__atc {
    width: 100%;
    padding: 10px 14px;
    font-size: 0.82rem;
  }

  .eco-pcard__sold {
    text-align: center;
    font-size: 0.75rem;
    color: var(--eco-text-mute);
    margin: 0;
    padding: 10px 0;
  }

  .eco-products__empty {
    text-align: center;
    color: var(--eco-text-soft);
  }

  .eco-products__empty > p {
    padding: 24px;
    background: var(--eco-glass);
    border: 1px solid var(--eco-border);
    border-radius: 16px;
    margin: 0 0 24px;
  }

  .eco-pcard--ph {
    opacity: 0.45;
    pointer-events: none;
  }

  .eco-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--eco-font-body);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 32px;
    padding: 14px 34px;
    cursor: pointer;
    border: 1px solid var(--eco-border);
    background: rgba(255, 255, 255, 0.06);
    color: var(--eco-text);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .eco-btn--silver {
    background: var(--eco-glass);
    color: var(--eco-silver-light);
    border-color: var(--eco-border);
  }

  .eco-btn--silver:hover,
  .eco-btn--silver:focus-visible {
    border-color: var(--eco-silver);
    color: #fff;
    transform: translateY(-2px);
    outline: none;
  }

  .eco-btn--glass:hover,
  .eco-btn--glass:focus-visible {
    background: var(--eco-accent);
    border-color: var(--eco-accent);
    box-shadow: 0 0 30px var(--eco-accent-glow);
    transform: translateY(-2px);
    outline: none;
  }

  .eco-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .eco-divider {
    height: 1px;
    border: none;
    background: linear-gradient(90deg, transparent 5%, var(--eco-border) 30%, rgba(212, 212, 216, 0.15) 50%, var(--eco-border) 70%, transparent 95%);
    margin: 0;
  }

  .eco-reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .eco-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  body.shopify-design-mode .eco-reveal {
    opacity: 1 !important;
    transform: none !important;
  }

  @media (prefers-reduced-motion: reduce) {
    .eco-reveal,
    .eco-pcard,
    .eco-pcard__media img,
    .eco-btn {
      transition: none !important;
      transform: none !important;
      opacity: 1 !important;
    }
  }
{% endstylesheet %}

<script>
  (function () {
    var root = document.getElementById('eco-products-{{ section.id }}');
    if (!root) return;
    var reveals = root.querySelectorAll('.eco-reveal');
    if (!reveals.length) return;
    if (document.body.classList.contains('shopify-design-mode') ||
        window.matchMedia('(prefers-reduced-motion: reduce)').matches ||
        !('IntersectionObserver' in window)) {
      for (var i = 0; i < reveals.length; i++) reveals[i].classList.add('is-visible');
      return;
    }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
    for (var j = 0; j < reveals.length; j++) io.observe(reveals[j]);
  })();
</script>

{% schema %}
{
  "name": "Products - Ecophoria",
  "tag": "section",
  "class": "shopify-section-eco-products",
  "settings": [
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name",
      "default": "Ecophoria"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Most loved"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Best Sellers"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View all button text",
      "default": "View All Products"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View all button link"
    },
    {
      "type": "text",
      "id": "empty_text",
      "label": "Empty state text",
      "default": "Select a collection in the theme editor to display products here."
    }
  ],
  "presets": [
    {
      "name": "Products - Ecophoria"
    }
  ]
}
{% endschema %}
