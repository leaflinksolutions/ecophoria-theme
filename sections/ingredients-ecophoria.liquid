<div class="eco-root eco-ing-root" id="eco-ingredients-{{ section.id }}">
  <section class="eco-ingredients" aria-labelledby="EcoIngHeading-{{ section.id }}">
    <div class="eco-container">

      <header class="eco-section-header eco-reveal">
        <p class="eco-eyebrow">{{ section.settings.eyebrow }}</p>
        <h2 id="EcoIngHeading-{{ section.id }}" class="eco-heading">
          {{ section.settings.heading }}
        </h2>
      </header>

      <ul class="eco-ing__grid" role="list">
        {% for block in section.blocks %}
          {% if block.type == 'ingredient' %}
            <li class="eco-ing__card eco-reveal{% if block.settings.url != blank %} eco-ing__card--linked{% endif %}" {{ block.shopify_attributes }}>
              {%- if block.settings.url != blank -%}
                <a href="{{ block.settings.url }}" class="eco-ing__link" aria-label="{{ block.settings.title | escape }}">
              {%- endif -%}
              <div class="eco-ing__media">
                {% if block.settings.image != blank %}
                  {{
                    block.settings.image
                    | image_url: width: 800
                    | image_tag:
                      widths: '240,360,540,720,800',
                      sizes: '(min-width: 990px) 22vw, (min-width: 600px) 45vw, 100vw',
                      loading: 'lazy',
                      alt: block.settings.image_alt | default: block.settings.title
                  }}
                {% else %}
                  <div class="eco-ing__ph" aria-hidden="true">
                    <span class="eco-ing__symbol">{{ block.settings.symbol | default: '◈' }}</span>
                  </div>
                {% endif %}
              </div>
              <div class="eco-ing__copy">
                <h3 class="eco-ing__title">{{ block.settings.title }}</h3>
                <p class="eco-ing__text">{{ block.settings.text }}</p>
              </div>
              {%- if block.settings.url != blank -%}
                </a>
              {%- endif -%}
            </li>
          {% endif %}
        {% endfor %}

        {% if section.blocks.size == 0 %}
          <li class="eco-ing__empty" role="status">
            <p>Add ingredient blocks in the theme editor to populate this section.</p>
          </li>
        {% endif %}
      </ul>

      {% if section.settings.cta_link != blank %}
        <div class="eco-ing__footer eco-reveal">
          <a class="eco-btn eco-btn--silver" href="{{ section.settings.cta_link }}">
            {{ section.settings.cta_text | default: 'View All Ingredients' }}
          </a>
        </div>
      {% endif %}

    </div>
  </section>
  <hr class="eco-divider" aria-hidden="true">
</div>

{% stylesheet %}
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Outfit:wght@300;400;500;600&display=swap');

  .eco-ing-root {
    --eco-bg: #080808;
    --eco-text: #f0efe8;
    --eco-text-soft: rgba(240, 239, 232, 0.6);
    --eco-accent: #2e5a45;
    --eco-accent-light: #3a7a5c;
    --eco-accent-glow: rgba(46, 90, 69, 0.4);
    --eco-silver: #b8b8bd;
    --eco-border: rgba(180, 180, 185, 0.12);
    --eco-glass: rgba(255, 255, 255, 0.04);
    --eco-glass-hover: rgba(255, 255, 255, 0.06);
    --eco-font-display: 'Cormorant Garamond', 'Garamond', Georgia, serif;
    --eco-font-body: 'Outfit', -apple-system, 'Helvetica Neue', Arial, sans-serif;
    background: var(--eco-bg);
    color: var(--eco-text);
    font-family: var(--eco-font-body);
    -webkit-font-smoothing: antialiased;
  }
  .eco-ing-root *,
  .eco-ing-root *::before,
  .eco-ing-root *::after {
    box-sizing: border-box;
  }
  .eco-ingredients {
    padding: clamp(60px, 10vw, 100px) 0;
    background: var(--eco-bg);
  }
  .eco-container {
    max-width: 1360px;
    margin: 0 auto;
    padding: 0 clamp(16px, 4vw, 28px);
  }
  .eco-section-header {
    text-align: center;
    margin-bottom: clamp(32px, 5vw, 56px);
  }
  .eco-eyebrow {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--eco-accent-light);
    margin: 0 0 8px;
  }
  .eco-heading {
    font-family: var(--eco-font-display);
    font-weight: 400;
    font-size: clamp(1.75rem, 3.5vw, 2.6rem);
    line-height: 1.1;
    margin: 0;
    color: var(--eco-text);
    max-width: 30ch;
    margin-inline: auto;
  }
  .eco-ing__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    align-items: stretch;
  }
  @media (min-width: 600px) {
    .eco-ing__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
  }
  @media (min-width: 990px) {
    .eco-ing__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .eco-ing__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .eco-ing__card {
    background: var(--eco-glass);
    border: 1px solid var(--eco-border);
    border-radius: 16px;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .eco-ing__footer {
    text-align: center;
    margin-top: clamp(32px, 5vw, 48px);
  }

  .eco-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--eco-font-body);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 32px;
    padding: 14px 34px;
    cursor: pointer;
    border: 1px solid transparent;
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .eco-btn--silver {
    background: var(--eco-glass);
    color: var(--eco-silver-light);
    border-color: var(--eco-border);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .eco-btn--silver:hover,
  .eco-btn--silver:focus-visible {
    border-color: var(--eco-silver);
    color: #fff;
    transform: translateY(-2px);
    outline: none;
  }
  .eco-ing__card:hover {
    transform: translateY(-4px);
    border-color: var(--eco-accent);
    background: var(--eco-glass-hover);
    box-shadow: 0 0 40px var(--eco-accent-glow);
  }
  .eco-ing__media {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #0d0d0d;
    position: relative;
  }
  .eco-ing__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .eco-ing__card:hover .eco-ing__media img {
    transform: scale(1.06);
  }
  .eco-ing__ph {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(145deg, #0e0e0e, #161618);
    position: relative;
  }
  .eco-ing__ph::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 80%, var(--eco-accent-glow) 0%, transparent 60%);
    opacity: 0.5;
    pointer-events: none;
  }
  .eco-ing__symbol {
    font-size: 3rem;
    color: var(--eco-silver);
    opacity: 0.4;
    z-index: 1;
  }
  .eco-ing__copy {
    padding: 20px 18px;
  }
  .eco-ing__title {
    font-family: var(--eco-font-display);
    font-size: 1.25rem;
    font-weight: 500;
    margin: 0 0 6px;
    color: var(--eco-text);
  }
  .eco-ing__text {
    font-size: 0.9rem;
    color: var(--eco-text-soft);
    margin: 0;
    line-height: 1.6;
  }
  .eco-ing__empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 40px 24px;
    background: var(--eco-glass);
    border: 1px solid var(--eco-border);
    border-radius: 16px;
    color: var(--eco-text-soft);
  }
  .eco-divider {
    height: 1px;
    border: none;
    background: linear-gradient(90deg, transparent 5%, var(--eco-border) 30%, rgba(212, 212, 216, 0.15) 50%, var(--eco-border) 70%, transparent 95%);
    margin: 0;
  }
  .eco-reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .eco-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  body.shopify-design-mode .eco-reveal {
    opacity: 1 !important;
    transform: none !important;
  }
  @media (prefers-reduced-motion: reduce) {
    .eco-reveal,
    .eco-ing__card,
    .eco-ing__media img {
      transition: none !important;
      transform: none !important;
      opacity: 1 !important;
    }
  }
{% endstylesheet %}

<script>
  (function () {
    var root = document.getElementById('eco-ingredients-{{ section.id }}');
    if (!root) return;
    var reveals = root.querySelectorAll('.eco-reveal');
    if (!reveals.length) return;
    if (document.body.classList.contains('shopify-design-mode') ||
        window.matchMedia('(prefers-reduced-motion: reduce)').matches ||
        !('IntersectionObserver' in window)) {
      for (var i = 0; i < reveals.length; i++) reveals[i].classList.add('is-visible');
      return;
    }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
    for (var j = 0; j < reveals.length; j++) io.observe(reveals[j]);
  })();
</script>

{% schema %}
{
